# Required
DATABASE_URL=postgres://postgres:root_postgres@localhost:5432/wulopay?sslmode=disable
PAYMENT_SERVICE_BASE_URL=http://localhost:8085

# Server
PORT=8088
ENV=local
LOG_LEVEL=info
MIGRATIONS_PATH=file://migrations

# HTTP client (outbound Payment / Trip / Chapa calls)
HTTP_CLIENT_TIMEOUT=10s

# Trip Service — required for pay-fare (GET /trips/:id?status=ACTIVE)
TRIP_SERVICE_BASE_URL=http://localhost:8086

# RabbitMQ — optional; leave RABBITMQ_URL empty to disable analytics/notification publishing
RABBITMQ_URL=amqp://haile:haile_rabbit@localhost:5672/
ANALYTICS_EXCHANGE=analytics_exchange
NOTIFICATION_EXCHANGE=notification.exchange

# Database pool (optional)
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=25
DB_CONN_MAX_IDLE=5m
DB_CONN_MAX_LIFE=30m
JWT_SECRET="gringo"
